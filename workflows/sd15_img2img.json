{
  "id": "sd15-img2img-v1",
  "name": "SD 1.5 Image to Image",
  "version": "1.0.0",
  "description": "Transform existing images using Stable Diffusion 1.5",
  "model": "SD 1.5",
  "type": "img2img",
  "metadata": {
    "creator": "SERI AI Studio",
    "created_at": "2023-10-16T00:00:00Z",
    "updated_at": "2023-10-16T00:00:00Z",
    "default_width": 512,
    "default_height": 512,
    "default_steps": 20,
    "default_cfg": 7.0,
    "default_denoise": 0.75
  },
  "nodes": {
    "load_image": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "image.jpg"
      }
    },
    "image_scale": {
      "class_type": "ImageScale",
      "inputs": {
        "image": "load_image",
        "width": 512,
        "height": 512,
        "keep_proportion": false
      }
    },
    "vae_encode": {
      "class_type": "VAEEncode",
      "inputs": {
        "pixels": "image_scale",
        "vae": "vae"
      }
    },
    "positive_prompt": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "a beautiful portrait painting of a woman, detailed features",
        "clip": "clip"
      }
    },
    "negative_prompt": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, bad anatomy, bad hands, cropped head",
        "clip": "clip"
      }
    },
    "sampler": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 42,
        "steps": 20,
        "cfg": 7.0,
        "sampler_name": "euler_a",
        "scheduler": "normal",
        "denoise": 0.75,
        "model": "model",
        "positive": "positive_prompt",
        "negative": "negative_prompt",
        "latent_image": "vae_encode"
      }
    },
    "decoder": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": "sampler",
        "vae": "vae"
      }
    },
    "save_image": {
      "class_type": "SaveImage",
      "inputs": {
        "images": "decoder",
        "filename_prefix": "sd15_img2img",
        "quality": 95,
        "filename_suffix": ""
      }
    }
  },
  "inputNodes": {
    "imageNode": "load_image",
    "promptNode": "positive_prompt",
    "negativePromptNode": "negative_prompt",
    "seedNode": "sampler",
    "stepsNode": "sampler",
    "cfgNode": "sampler",
    "denoiseNode": "sampler"
  },
  "outputNodes": {
    "imageNode": "save_image"
  },
  "parameterMapping": {
    "image_url": "image",
    "prompt": "text",
    "negative_prompt": "text",
    "width": "width",
    "height": "height",
    "seed": "seed",
    "steps": "steps",
    "cfg_scale": "cfg",
    "denoise": "denoise"
  }
}